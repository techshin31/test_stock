# 사용자 식별 (apps/user register로 등록한 이메일)
USER_EMAIL=""

# 자격증명 복호화 키 (apps/user/.env의 CREDENTIAL_ENCRYPTION_KEY와 동일한 값)
CREDENTIAL_ENCRYPTION_KEY=""

# 거래 환경
KIS_ENV=paper
BROKER_CODE=KIS

# 실주문 허용 (KIS_ENV=real 일 때만 유효)
ALLOW_LIVE_ORDER=true

# 전략 설정
STRATEGY_NAME=risk_neutral
DAILY_LOSS_LIMIT=0.10
CYCLE_INTERVAL_SEC=60

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin1234
POSTGRES_DB=quantpilot_db
