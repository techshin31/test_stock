# 사용자 정보
USER_EMAIL=
USER_DISPLAY_NAME=

# 증권사 설정
BROKER_CODE=KIS
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ENV=paper

# 주식 계좌 (필수)
KIS_DOMESTIC_STOCK_ACCOUNT_NO=
KIS_DOMESTIC_STOCK_ACCOUNT_PRODUCT_CODE=01

# 선물 계좌 (선택 — 없으면 비워두세요)
KIS_DOMESTIC_FUTURES_ACCOUNT_NO=
KIS_DOMESTIC_FUTURES_ACCOUNT_PRODUCT_CODE=03

# 실주문 허용 여부 (KIS_ENV=real 일 때만 유효)
ALLOW_LIVE_ORDER=false

# 자격증명 암호화 키
# 최초 생성: python -c "from core.utils.crypto import generate_key; print(generate_key())"
CREDENTIAL_ENCRYPTION_KEY=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=quantpilot_db
