  "sources": [
    {
      "id": "paper_reconciliation",
      "label": "PAPER 계좌 대사 노트북 (5억 원금·기준선·현재 스냅샷)",
      "path": "reports/analysis/paper_performance_diagnostic_2026-07-22.ipynb",
      "query": {
        "engine": "PostgreSQL",
        "language": "sql",
        "description": "지정 시각 이전의 최신 PAPER 잔고를 5억 원금 및 2026-07-20 인증 기준선과 대사",
        "sql": "WITH latest AS (SELECT bh.total_value::numeric AS current_total FROM balance_history bh JOIN strategies s ON s.id = bh.strategy_id WHERE s.name = 'aggressive' AND bh.execution_venue_code = 'PAPER' AND bh.account_scope = '***9904-01' AND (bh.recorded_at AT TIME ZONE 'Asia/Seoul') <= TIMESTAMP '2026-07-22 09:59:17' ORDER BY bh.recorded_at DESC LIMIT 1) SELECT current_total, current_total - 500000000 AS inception_pnl, current_total / 500000000 - 1 AS return_vs_start, current_total - 463025590 AS post_baseline_pnl, current_total / 463025590 - 1 AS return_vs_baseline FROM latest;",
        "executed_at": "2026-07-22T09:59:17+09:00",
        "tables_used": [
          "balance_history",
          "strategies"
        ],
        "filters": [
          "strategy=aggressive",
          "execution_venue_code=PAPER",
          "account_scope=***9904-01",
          "recorded_at <= 2026-07-22 09:59:17 KST"
        ],
        "metric_definitions": [
          "최초 원금 수익률 = 현재 평가액 / 500,000,000 - 1; 입출금이 없다는 가정",
          "공식 기준선 수익률 = 현재 평가액 / 463,025,590 - 1"
        ]
      }
    },
    {
      "id": "paper_orders",
      "label": "PostgreSQL PAPER 주문 이력",
      "path": "reports/analysis/paper_performance_diagnostic_2026-07-22.ipynb",
      "query": {
        "engine": "PostgreSQL",
        "language": "sql",
        "description": "aggressive 전략의 일자별 주문 상태와 체결금액 집계",
        "sql": "SELECT (o.created_at AT TIME ZONE 'Asia/Seoul')::date AS trade_date, COUNT(*) AS orders, COUNT(*) FILTER (WHERE o.order_status_code = 'FILLED') AS filled, COUNT(*) FILTER (WHERE o.order_status_code = 'REJECTED') AS rejected, COUNT(*) FILTER (WHERE o.order_status_code = 'CANCELLED') AS cancelled, SUM(COALESCE(o.filled_qty, 0) * COALESCE(o.avg_fill_price, 0)) AS filled_notional, COUNT(DISTINCT REPLACE(o.symbol, '.KS', '')) AS symbols FROM orders o JOIN strategies s ON s.id = o.strategy_id WHERE s.name = 'aggressive' GROUP BY 1 ORDER BY 1;",
        "executed_at": "2026-07-22T09:59:17+09:00",
        "tables_used": [
          "orders",
          "strategies"
        ],
        "filters": [
          "strategy=aggressive",
          "all available order dates through 2026-07-22 09:59 KST"
        ],
        "metric_definitions": [
          "체결금액 = Σ(filled_qty × avg_fill_price), 매수와 매도의 절대 체결금액 합계",
          "원금 대비 회전 = 일 체결금액 / 500,000,000"
        ]
      }
    },
    {
      "id": "execution_state",
      "label": "PAPER 의사결정·주문 상태",
      "path": "logs/paper/decision_history.jsonl"
    },
    {
      "id": "pbo_paper",
      "label": "Probability of Backtest Overfitting",
      "href": "https://papers.ssrn.com/sol3/Papers.cfm?abstract_id=2326253"
    },
    {
      "id": "dsr_paper",
      "label": "Deflated Sharpe Ratio",
      "href": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=2460551"
    },
    {
      "id": "kis_official",
      "label": "한국투자증권 Open API 공식 저장소",
      "href": "https://github.com/koreainvestment/open-trading-api"
    },
    {
      "id": "holdings_snapshot",
      "label": "PAPER 보유 종목 장중 스냅샷",
      "path": "logs/paper/dashboard_state.json",
      "query": {
        "engine": "PostgreSQL-compatible VALUES",
        "language": "sql",
        "description": "2026-07-22 09:59:17 KST 대시보드 스냅샷의 보유 종목 원가·현재가를 재계산",
        "sql": "WITH p(name,ticker,qty,avg_price,current_price) AS (VALUES ('F&F','383220.KS',915,78891.083,73200.0), ('코웨이','021240.KS',753,95021.912,92700.0), ('한국타이어앤테크놀로지','161390.KS',1001,69400.916,72200.0), ('달바글로벌','483650.KS',299,200253.691,233500.0)) SELECT name,ticker,qty,avg_price,current_price,qty*current_price AS market_value,(current_price-avg_price)*qty AS unrealized_pnl,current_price/avg_price-1 AS return_rate FROM p;",
        "executed_at": "2026-07-22T09:59:17+09:00",
        "tables_used": [
          "logs/paper/dashboard_state.json"
        ],
        "filters": [
          "mode=PAPER",
          "account_scope=***9904-01",
          "snapshot=2026-07-22 09:59:17 KST"
        ],
        "metric_definitions": [
          "미실현 손익 = (현재가 - 평균단가) × 수량",
          "종목 수익률 = 현재가 / 평균단가 - 1"
        ]
      }
    }
  ]
}
